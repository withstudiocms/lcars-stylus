// LCARS table

// Baseline defaults
table 
  border none

table td,th 
  text-align left
  vertical-align top

table th 
  font-weight bolder

table.standard-header 
  border-spacing 2rem .25rem
  margin-left -2rem

table.standard-header th 
  border-bottom .1rem solid

table.standard-header tbody:before 
  /* only works without border-collapse, note */
  line-height .1em 
  content "\00a0"  /*i.e., &nbsp;*/
  color black  /* background color */
  display block 

table.lcars-table.with-caption
  &.caption-left caption
    margin-right -0.5rem
    margin-bottom 0.5rem
    text-align left
    border-left 0.8em solid
    border-right 32rem solid
    border-radius 0.5em
    padding-left 0.33em
    padding-bottom -0.15em
  &.caption-right caption
    margin-left -0.5rem
    margin-bottom 0.5rem
    text-align right
    border-right 0.8em solid
    border-left 32rem solid
    border-radius 0.5em
    padding-right 0.33em
    padding-bottom -0.15em

animationDuration   = 8s
animationFramecount = 10
for animationFrameIdx in (1..animationFramecount)
  table.lcars-table.scanning tr:nth-child({animationFrameIdx}) td 
    background transparent
    animation-name rowscan
    animation-duration animationDuration
    animation-delay ((animationDuration / animationFramecount) * animationFrameIdx)
    animation-iteration-count infinite

@keyframes rowscan 
  0% {
    filter brightness(1.0)
  }
  3% {
    filter brightness(1.65)
  }
  10% {
    filter brightness(1.65)
  }
  14% {
    filter brightness(1.0)
  }
  100% {
    filter brightness(1.0)
  }


animationDuration   = 2s
animationFramecount = 12
for animationFrameIdx in (1..animationFramecount)
  table.lcars-table.scanning-fast tr:nth-child({animationFrameIdx}) td 
    background transparent
    animation-name rowscan-fast
    animation-duration animationDuration
    animation-delay ((animationDuration / animationFramecount) * animationFrameIdx)
    animation-iteration-count infinite

@keyframes rowscan-fast 
  0% {
    filter brightness(1.0)
  }
  3% {
    filter brightness(1.65)
  }
  10% {
    filter brightness(1.65)
  }
  14% {
    filter brightness(1.0)
  }
  100% {
    filter brightness(1.0)
  }

