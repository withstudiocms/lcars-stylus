// LCARS -- Fonts

html, body
  font-family primary-font-family
  color white

h1
  font-size 300%
  font-weight bold

h2
  font-size 270%
  font-weight bold

h3
  font-size 230%
  font-weight bold

h4
  font-size 210%
  font-weight bold

h5
  font-size 190%
  font-weight bold

h6
  font-size 170%
  font-weight bold
