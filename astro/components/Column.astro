---
import type { SupportsUnitSizing } from "../types";
import type { HTMLAttributes } from "astro/types";

interface Props extends SupportsUnitSizing, HTMLAttributes<"div"> {
    startSpace?: boolean;
}

const { u, startSpace, ...props } = Astro.props;
---

<div
    {...props}
    class:list={[
        "lcars-column",
        u && `lcars-u-${u}`,
        startSpace && "start-space",
    ]}
>
    <slot />
</div>
