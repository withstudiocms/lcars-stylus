// LCARS Baseline Body and Document-level Defaults

/* First make the default (and therefore including window) scrollbar unobtrusive and more LCARS-like*/
::-webkit-scrollbar
  width: 1em

::-webkit-scrollbar-track 
  background-color:black

::-webkit-scrollbar-thumb
  background-color: dimgrey
  outline: 1px solid dimgrey


body
  background-color black

pre
  display inline
  white-space pre-line
  word-wrap break-word

hr
  width 100%
  border none
  border-bottom .2rem solid #FFFFFF

p,
h1,
h2,
h3
  margin-top 1em